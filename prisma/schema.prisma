generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Settings {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Message {
  id      String   @id @default(cuid())
  name    String
  email   String
  brand   String   @default("")
  message String
  date    DateTime @default(now())
  read    Boolean  @default(false)
}

model VisitorLog {
  id              String   @id @default(cuid())
  ipHash          String   // Anonymized IP hash to avoid storing raw PII
  pathname        String
  userAgent       String
  device          String   // e.g. "Mobile", "Desktop"
  browser         String
  os              String?  // e.g. "Windows", "Android", "iOS"
  country         String?  // Derived from x-vercel-ip-country
  city            String?  // Derived from x-vercel-ip-city
  referrer        String?  // Where they came from (Domain only)
  language        String?  // e.g. "en-US", "de"
  sessionDuration Int?     // Seconds spent on site
  visitedAt       DateTime @default(now())
}
